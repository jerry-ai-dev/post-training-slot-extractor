# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.worktrees/

# Local environment
.env
.env.*
!.env.example

# Heavy / generated artifacts
data/raw/*
data/interim/*
data/processed/*
data/eval/*
# 评估集破例入库（尺子需 git 版本化）
!data/eval/test.jsonl
!data/eval/DATASET_CARD.md
!data/eval/dataset_contract.json
!data/eval/test.sha256
models/base/*
models/adapters/*
models/merged/*
models/gguf/*
models/imatrix/*
experiments/runs/*
experiments/baselines/*
reports/generated/*
!reports/generated/scorecard-gpt-5.6-sol.json

# Local llama.cpp binaries (downloaded per-machine, never committed)
deployment/llama_cpp/bin/*
!deployment/llama_cpp/bin/.gitkeep

# Keep directory placeholders
!.gitkeep
!data/**/.gitkeep
!models/**/.gitkeep
!experiments/**/.gitkeep
!reports/**/.gitkeep

# Logs
*.log
logs/
